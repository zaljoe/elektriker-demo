---
import Layout from '../layouts/Layout.astro';
import { COMPANY } from '../config';

const areas = [
  { name: "Göteborg",     text: `${COMPANY.name} är baserat i Göteborg. Vi känner till stadens bostadsbestånd, lokala byggregler och nätbolag väl. De flesta uppdrag i Göteborg hanteras samma dag.` },
  { name: "Mölndal",      text: `Vi utför regelbundna eluppdrag i Mölndal för såväl villor och bostadsrätter som kontor och industrilokaler. Snabb responstid från vår bas i Göteborg.` },
  { name: "Partille",     text: `Partille är ett av våra mest aktiva serviceområden. Vanligaste uppdragen är centralbyten, EV-laddare och ominstallationer i äldre villor.` },
  { name: "Kungsbacka",   text: `Vi täcker hela Kungsbacka-området och når dit inom ordinarie responstid. Alla tjänster tillgängliga — akutjour inkluderat.` },
  { name: "Kungälv",      text: `Fasta kunder i Kungälv för både bostads- och kommersiella uppdrag. Vi känner till de lokala bygglovsrutinerna och hanterar tillstånd åt dig.` },
  { name: "Lerum",        text: `Vi betjänar husägare och företag i Lerum. Belysningsinstallationer, säkringsbyten och EV-laddare är vanligaste uppdragen i området.` },
  { name: "Härryda",      text: `Härryda och Mölnlycke täcks av vår ordinarie servicezon. Snabb utryckning och fullt licensierade tjänster för bostad och näringsliv.` },
  { name: "Stenungsund",  text: `Vi når Stenungsund inom rimlig restid. Akutjour tillgänglig dygnet runt — ring oss och vi är på väg.` },
  { name: "Öckerö",       text: `Även skärgårdskommunen Öckerö finns inom vårt serviceområde. Kontakta oss för tillgänglighet och restidsbedömning.` },
  { name: "Alingsås",     text: `Vi utför eluppdrag i Alingsås med samma standard som i Göteborg — licensierad personal, fast pris och 2 års garanti på arbetet.` },
];

const jsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Eltjänster",
  "provider": { "@type": "LocalBusiness", "name": COMPANY.name },
  "areaServed": areas.map(a => ({ "@type": "City", "name": a.name }))
});
---
<Layout
  title={`Serviceområden — ${COMPANY.city} & omnejd | ${COMPANY.name}`}
  description={`${COMPANY.name} betjänar ${COMPANY.city} och alla omkringliggande orter. Licensierad elektriker, svarar samma dag. Ring ${COMPANY.phone}.`}
  canonical="https://REPLACE-WITH-DOMAIN.com/service-areas/"
  jsonld={jsonld}
>

  <!-- Breadcrumb -->
  <div style="background:var(--bg-alt);border-bottom:1px solid var(--border);padding:0.65rem 0;font-size:0.78rem;color:var(--text-muted);">
    <div class="container" style="display:flex;align-items:center;gap:0.4rem;">
      <a href="/" style="color:var(--text-muted);transition:color .15s;" onmouseenter="this.style.color='var(--brand)'" onmouseleave="this.style.color='var(--text-muted)'">Hem</a>
      <span style="color:var(--text-light);">›</span>
      <span style="color:var(--brand);font-weight:600;">Serviceområden</span>
    </div>
  </div>

  <!-- Hero -->
  <section style="position:relative;background:var(--bg-dark);padding:5rem 0 4rem;overflow:hidden;text-align:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(31,41,55,0.97) 0%,rgba(31,41,55,0.85) 100%);" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;max-width:640px;">
      <span class="section-label" style="margin-bottom:0.75rem;">Var vi arbetar</span>
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;color:#fff;letter-spacing:-0.03em;margin-bottom:1rem;">Serviceområden</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.75);line-height:1.75;">Vi betjänar {COMPANY.city} och alla omkringliggande orter. Svarar samma dag i de flesta områden.</p>
    </div>
  </section>

  <!-- Area cards -->
  <section class="section" style="background:var(--bg-page);">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem;margin-bottom:3rem;">
        {areas.map(area => (
          <div style="background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);padding:1.75rem;transition:box-shadow .2s,border-color .2s;position:relative;overflow:hidden;" onmouseenter="this.style.boxShadow='var(--shadow-card)';this.style.borderColor='rgba(119,169,237,0.3)'" onmouseleave="this.style.boxShadow='';this.style.borderColor='var(--border)'">
            <h2 style="font-size:1.05rem;font-weight:700;color:var(--text-main);margin-bottom:0.6rem;display:flex;align-items:center;gap:0.6rem;">
              <svg width="15" height="15" fill="none" stroke="var(--brand)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {area.name}
            </h2>
            <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.7;">{area.text}</p>
          </div>
        ))}
      </div>

      <!-- Google Maps facade — laddas vid klick -->
      <div class="map-facade" data-height="380" style="border-radius:var(--radius-md);overflow:hidden;border:1.5px solid var(--border);height:380px;cursor:pointer;position:relative;background:#e8eef4;display:flex;align-items:center;justify-content:center;">
        <img src="/map-preview.png" alt="Karta Göteborg serviceområde" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;display:block;" />
        <div style="position:relative;z-index:1;text-align:center;background:rgba(255,255,255,0.9);border-radius:999px;padding:0.6rem 1.5rem;display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;font-weight:600;color:#1a1a2e;box-shadow:0 2px 8px rgba(0,0,0,0.12);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Visa karta
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:var(--bg-alt);">
    <div class="container" style="max-width:540px;text-align:center;">
      <div style="background:#fff;border-radius:var(--radius-md);box-shadow:var(--shadow-card);padding:3rem 2.5rem;">
        <h2 class="section-title">Osäker på om vi täcker ditt område?</h2>
        <p style="color:var(--text-muted);font-size:0.95rem;line-height:1.7;margin-bottom:1.75rem;">Ring och fråga. Kan vi inte hjälpa till hänvisar vi vidare till någon som kan.</p>
        <a href={COMPANY.phoneTel} class="btn btn-primary" style="gap:0.5rem;">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Ring {COMPANY.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
