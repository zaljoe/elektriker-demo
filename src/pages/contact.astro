---
import Layout from '../layouts/Layout.astro';
import { COMPANY, SERVICES } from '../config';

const jsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": COMPANY.name,
  "telephone": COMPANY.phone,
  "email": COMPANY.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": COMPANY.address,
    "addressLocality": COMPANY.city,
    "postalCode": COMPANY.zip
  },
  "openingHours": ["Mo-Fr 07:00-18:00", "Sa 08:00-16:00"]
});
---
<Layout
  title={`Kontakta ${COMPANY.name} — Gratis offert i ${COMPANY.city}`}
  description={`Begär en gratis eloffert från ${COMPANY.name} i ${COMPANY.city}. Ring ${COMPANY.phone} eller fyll i kontaktformuläret. Jourtelefon dygnet runt.`}
  canonical="https://REPLACE-WITH-DOMAIN.com/contact/"
  jsonld={jsonld}
>

  <!-- Emergency bar -->
  <div style="background:var(--brand);padding:0.85rem 0;text-align:center;">
    <div class="container">
      <p style="font-weight:600;color:#fff;font-size:0.875rem;">
        Elektrisk nödsituation?
        <a href={COMPANY.phoneTel} style="color:#fff;text-decoration:underline;margin-left:0.5rem;font-weight:700;">Ring {COMPANY.phone} — Jour dygnet runt</a>
      </p>
    </div>
  </div>

  <!-- Hero -->
  <section style="position:relative;background:var(--bg-dark);padding:4.5rem 0 4rem;overflow:hidden;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(31,41,55,0.97) 0%,rgba(31,41,55,0.85) 100%);" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;max-width:640px;text-align:center;">
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;color:#fff;letter-spacing:-0.03em;margin-bottom:1rem;">Begär gratis offert</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.75);line-height:1.75;">Fyll i formuläret nedan så svarar vi inom 2 timmar på vardagar. För akuta ärenden, ring oss direkt.</p>
    </div>
  </section>

  <!-- Contact grid -->
  <section class="section" style="background:var(--bg-page);">
    <div class="container">
      <div class="contact-grid">

        <!-- Form -->
        <div style="background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);padding:2.5rem;box-shadow:var(--shadow-card);">
          <h2 style="font-size:1.4rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.4rem;">Skicka förfrågan</h2>
          <p style="color:var(--text-muted);font-size:0.875rem;margin-bottom:2rem;">Fält markerade med * är obligatoriska.</p>

          <form style="display:flex;flex-direction:column;gap:1.25rem;" action="#" method="POST">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;" class="form-row">
              <div>
                <label for="fname" style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:0.4rem;">Namn *</label>
                <input id="fname" name="name" type="text" required placeholder="Anna Svensson" style="width:100%;padding:0.75rem 0.875rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:0.9rem;color:var(--text-main);background:#fff;outline:none;transition:border-color .15s;" onfocus="this.style.borderColor='var(--brand)'" onblur="this.style.borderColor='var(--border)'" />
              </div>
              <div>
                <label for="fphone" style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:0.4rem;">Telefon *</label>
                <input id="fphone" name="phone" type="tel" required placeholder="070-000 00 00" style="width:100%;padding:0.75rem 0.875rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:0.9rem;color:var(--text-main);background:#fff;outline:none;transition:border-color .15s;" onfocus="this.style.borderColor='var(--brand)'" onblur="this.style.borderColor='var(--border)'" />
              </div>
            </div>
            <div>
              <label for="faddress" style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:0.4rem;">Adress för uppdraget</label>
              <input id="faddress" name="address" type="text" placeholder="Gatuadress till jobbet" style="width:100%;padding:0.75rem 0.875rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:0.9rem;color:var(--text-main);background:#fff;outline:none;transition:border-color .15s;" onfocus="this.style.borderColor='var(--brand)'" onblur="this.style.borderColor='var(--border)'" />
            </div>
            <div>
              <label for="fservice" style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:0.4rem;">Typ av tjänst *</label>
              <div style="position:relative;">
              <select id="fservice" name="service" required style="width:100%;padding:0.75rem 2.5rem 0.75rem 0.875rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:0.9rem;color:var(--text-main);background:#fff;outline:none;transition:border-color .15s;appearance:none;cursor:pointer;" onfocus="this.style.borderColor='var(--brand)'" onblur="this.style.borderColor='var(--border)'">
                <option value="">Välj tjänst...</option>
                {SERVICES.map(s => <option value={s.slug}>{s.title}</option>)}
                <option value="other">Annat / vet ej</option>
              </select>
              <svg style="position:absolute;right:0.875rem;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" fill="none" stroke="var(--text-muted)" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
            <div>
              <label for="fdesc" style="display:block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-muted);margin-bottom:0.4rem;">Beskrivning *</label>
              <textarea id="fdesc" name="description" required rows="4" placeholder="Beskriv kort vad du behöver. Ju mer detaljer, desto snabbare kan vi hjälpa till." style="width:100%;padding:0.75rem 0.875rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:var(--font);font-size:0.9rem;color:var(--text-main);background:#fff;outline:none;resize:vertical;transition:border-color .15s;" onfocus="this.style.borderColor='var(--brand)'" onblur="this.style.borderColor='var(--border)'"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="font-size:0.9rem;padding:0.95rem 2rem;justify-content:center;gap:0.5rem;">
              Skicka förfrågan
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </button>
            <p style="font-size:0.72rem;color:var(--text-light);text-align:center;">Vi svarar inom 2 timmar på vardagar. Aldrig spam.</p>
          </form>
        </div>

        <!-- Contact info -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">

          <div style="background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);padding:1.75rem;">
            <h3 style="font-size:1rem;font-weight:700;margin-bottom:1.25rem;">Kontaktuppgifter</h3>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <a href={COMPANY.phoneTel} style="display:flex;align-items:center;gap:0.875rem;font-size:0.925rem;color:var(--text-main);font-weight:600;">
                <div style="width:36px;height:36px;background:rgba(119,169,237,0.08);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="16" height="16" fill="none" stroke="var(--brand)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                {COMPANY.phone}
              </a>
              <a href={`mailto:${COMPANY.email}`} style="display:flex;align-items:center;gap:0.875rem;font-size:0.925rem;color:var(--text-main);">
                <div style="width:36px;height:36px;background:rgba(119,169,237,0.08);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="16" height="16" fill="none" stroke="var(--brand)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                {COMPANY.email}
              </a>
              <div style="display:flex;align-items:flex-start;gap:0.875rem;font-size:0.925rem;color:var(--text-muted);">
                <div style="width:36px;height:36px;background:rgba(119,169,237,0.08);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:0.1rem;">
                  <svg width="16" height="16" fill="none" stroke="var(--brand)" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>{COMPANY.address}<br />{COMPANY.city}, {COMPANY.zip}</div>
              </div>
            </div>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);padding:1.75rem;">
            <h3 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">Öppettider</h3>
            <p style="font-size:0.9rem;color:var(--text-muted);margin-bottom:1rem;">{COMPANY.hours}</p>
            <div style="padding:0.85rem 1rem;background:rgba(119,169,237,0.06);border:1px solid rgba(119,169,237,0.2);border-radius:var(--radius-sm);display:flex;align-items:center;gap:0.75rem;">
              <span class="pulse-dot" style="margin:0;flex-shrink:0;"></span>
              <p style="font-size:0.85rem;color:var(--brand);font-weight:700;">Jourtelefon dygnet runt, 7 dagar i veckan</p>
            </div>
          </div>

          <!-- Google Maps facade — laddas vid klick -->
          <div class="map-facade" data-height="220" style="border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--border);height:220px;cursor:pointer;position:relative;background:#e8eef4;display:flex;align-items:center;justify-content:center;">
            <img src="/ny.jpg" alt="Karta Göteborg" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;display:block;" />
            <div style="position:relative;z-index:1;text-align:center;background:rgba(255,255,255,0.9);border-radius:999px;padding:0.5rem 1.25rem;display:flex;align-items:center;gap:0.5rem;font-size:0.82rem;font-weight:600;color:#1a1a2e;box-shadow:0 2px 8px rgba(0,0,0,0.12);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Visa karta
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .contact-grid { display: grid; gap: 2.5rem; grid-template-columns: 1fr; }
    @media(min-width:900px){ .contact-grid { grid-template-columns: 1.2fr 0.8fr; } }
    @media(max-width:480px){ .form-row { grid-template-columns: 1fr !important; } }
  </style>
</Layout>
