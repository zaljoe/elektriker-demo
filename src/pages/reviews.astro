---
import Layout from '../layouts/Layout.astro';
import { COMPANY } from '../config';
import TestimonialsSection from '../components/ui/TestimonialV2';

const reviews = [
  { name: "Sara M.",    date: "Mars 2025",     rating: 5, service: "Akutreparation",      text: "Ringde klockan 20 för en utlöst jordfelsbrytare. Var på plats inom 45 minuter, hittade felet och hade allt klart till 21:30. Ärlrigt pris, ingen jourtillägg." },
  { name: "David K.",   date: "Februari 2025", rating: 5, service: "Panelbyte",           text: "Byte från 100A till 200A klart på en dag. De skötte tillstånd, besiktning och nätkoordinering. Priset stämde exakt med offerten — inte en krona mer." },
  { name: "Maria T.",   date: "Januari 2025",  rating: 5, service: "EV-laddare",          text: "Level 2-laddare installerad på en halvdag, allt enligt regler. Teknikern gick igenom allt som gjorts och svarade på varje fråga." },
  { name: "James R.",   date: "December 2024", rating: 5, service: "Kommersiell el",      text: "Kopplade om vårt kontor under en helg. Professionella, städade upp efter sig och klart i tid. Störde inte verksamheten alls." },
  { name: "Karin B.",   date: "April 2025",    rating: 5, service: "Ominstallation",      text: "Ominstallerades halva huset under renoveringen. Dök upp varje dag, kommunicerade tydligt och godkändes vid besiktningen första gången." },
  { name: "Göran N.",   date: "Januari 2025",  rating: 5, service: "Akutreparation",      text: "Brännlukt från ett vägguttag klockan 23. De kom ut, hittade en överhettad kopplingsdosa och säkrade allt. Mycket betryggande." },
  { name: "Susan P.",   date: "Mars 2025",     rating: 5, service: "Belysning",           text: "Inbyggd belysning i kök och vardagsrum. Transformerade båda rummen totalt. Bra råd om placering." },
  { name: "Tom H.",     date: "Februari 2025", rating: 5, service: "Felsökning",          text: "Flimrande lampor i månader. Annat företag hittade inget. Dessa hittade felet på 20 minuter — lös anslutning i kopplingsdosan." },
  { name: "Carol W.",   date: "Januari 2025",  rating: 5, service: "Undercentralsarbete", text: "Ny undercentral för garage. Matningsledning, central installerad och godkänd på två dagar. Nöjdare kan man inte bli." },
];

const jsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": COMPANY.name,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": COMPANY.rating,
    "reviewCount": reviews.length.toString()
  },
  "review": reviews.map(r => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.name },
    "reviewRating": { "@type": "Rating", "ratingValue": r.rating },
    "reviewBody": r.text,
    "datePublished": "2025"
  }))
});
---
<Layout
  title={`Recensioner — ${COMPANY.rating}★ Google-betyg | ${COMPANY.name}`}
  description={`Läs verifierade recensioner om ${COMPANY.name} i ${COMPANY.city}. ${COMPANY.rating} stjärnor av ${COMPANY.reviewCount} Google-recensioner.`}
  canonical="https://REPLACE-WITH-DOMAIN.com/reviews/"
  jsonld={jsonld}
>

  <!-- Breadcrumb -->
  <div style="background:var(--bg-alt);border-bottom:1px solid var(--border);padding:0.65rem 0;font-size:0.78rem;color:var(--text-muted);">
    <div class="container" style="display:flex;align-items:center;gap:0.4rem;">
      <a href="/" style="color:var(--text-muted);transition:color .15s;" onmouseenter="this.style.color='var(--brand)'" onmouseleave="this.style.color='var(--text-muted)'">Hem</a>
      <span style="color:var(--text-light);">›</span>
      <span style="color:var(--brand);font-weight:600;">Recensioner</span>
    </div>
  </div>

  <!-- Animated testimonials -->
  <TestimonialsSection client:load />

  <!-- CTA -->
  <section class="section" style="background:var(--bg-alt);">
    <div class="container" style="max-width:580px;text-align:center;">
      <div style="background:#fff;border-radius:var(--radius-md);box-shadow:var(--shadow-card);padding:3rem 2.5rem;">
        <h2 class="section-title">Redo att bli vår nästa nöjda kund?</h2>
        <p style="color:var(--text-muted);font-size:0.95rem;line-height:1.7;margin-bottom:1.75rem;">Begär en gratis offert idag. Licensierade, försäkrade och backade av {COMPANY.reviewCount}+ femstjärniga recensioner.</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.85rem;justify-content:center;">
          <a href="/contact/" class="btn btn-primary" style="gap:0.5rem;">
            Begär gratis offert
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href={COMPANY.phoneTel} class="btn btn-outline" style="gap:0.5rem;">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Ring {COMPANY.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
