---
import Layout from '../../layouts/Layout.astro';
import { COMPANY, SERVICES } from '../../config';
---
<Layout
  title={`Eltjänster i ${COMPANY.city} | ${COMPANY.name}`}
  description={`Bläddra bland alla eltjänster från ${COMPANY.name} i ${COMPANY.city}. Licensierad, försäkrad, tydliga priser. Ring ${COMPANY.phone}.`}
  canonical="https://REPLACE-WITH-DOMAIN.com/services/"
>

  <!-- Breadcrumb -->
  <div style="background:var(--bg-alt);border-bottom:1px solid var(--border);padding:0.65rem 0;font-size:0.78rem;color:var(--text-muted);">
    <div class="container" style="display:flex;align-items:center;gap:0.4rem;">
      <a href="/" style="color:var(--text-muted);transition:color .15s;" onmouseenter="this.style.color='var(--brand)'" onmouseleave="this.style.color='var(--text-muted)'">Hem</a>
      <span style="color:var(--text-light);">›</span>
      <span style="color:var(--brand);font-weight:600;">Tjänster</span>
    </div>
  </div>

  <!-- Hero -->
  <section style="position:relative;background:var(--bg-dark);padding:5rem 0 4rem;overflow:hidden;text-align:center;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(31,41,55,0.97) 0%,rgba(31,41,55,0.85) 100%);" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;max-width:640px;">
      <span class="section-label" style="margin-bottom:0.75rem;">Vad vi gör</span>
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:800;color:#fff;letter-spacing:-0.03em;margin-bottom:1rem;">Eltjänster i {COMPANY.city}</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.75);line-height:1.75;">Licensierad, försäkrad och transparent i prissättning. Välj en tjänst nedan för att läsa mer.</p>
    </div>
  </section>

  <section class="section" style="background:var(--bg-alt);">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem;">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}/`} style="display:flex;flex-direction:column;gap:1rem;background:#fff;border:1px solid var(--border);border-radius:var(--radius-md);padding:1.75rem;text-decoration:none;transition:box-shadow .2s,border-color .2s;position:relative;overflow:hidden;" onmouseenter="this.style.boxShadow='var(--shadow-card)';this.querySelector('.sc-border').style.transform='scaleY(1)'" onmouseleave="this.style.boxShadow='';this.querySelector('.sc-border').style.transform='scaleY(0)'">
            <div class="sc-border" style="position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--brand);transform:scaleY(0);transition:transform .2s;transform-origin:bottom;"></div>
            <div style="width:40px;height:40px;background:rgba(119,169,237,0.08);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;">
              <svg width="20" height="20" fill="none" stroke="var(--brand)" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <h2 style="font-size:1rem;font-weight:700;color:var(--text-main);margin-bottom:0.4rem;">{s.title}</h2>
              <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.65;">{s.short}</p>
            </div>
            <span style="font-size:0.78rem;font-weight:700;color:var(--brand);margin-top:auto;">Läs mer →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm" style="background:var(--bg-page);">
    <div class="container" style="max-width:540px;text-align:center;">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.75rem;">Hitta du inte vad du söker?</h2>
      <p style="color:var(--text-muted);font-size:0.95rem;margin-bottom:1.5rem;">Ring oss eller skicka in en förfrågan — vi hanterar de flesta eluppdrag för bostäder och företag.</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.85rem;justify-content:center;">
        <a href="/contact/" class="btn btn-primary" style="gap:0.5rem;">
          Begär offert
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={COMPANY.phoneTel} class="btn btn-outline" style="gap:0.5rem;">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Ring {COMPANY.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
